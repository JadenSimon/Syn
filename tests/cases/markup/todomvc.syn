/// <reference lib="jsx" />
/// <reference lib="es2015" />

// https://todomvc.com/examples/backbone/dist/

<#component App() {
    interface TodoData {
        label: string
        completed?: boolean
        _comp?: Todo
    }

    let editingTodo: TodoData | undefined
    let filterState: 'all' | 'completed' | 'active' = 'all' as any
    const todos: TodoData[] = []
    function deleteTodo(d: TodoData) {
        const ind = todos.indexOf(d)
        if (ind === -1) return
        update root {
            todos.splice(ind, 1)
            if (editingTodo === d) {
                editingTodo = undefined
            }
        }
    }

    const stored = localStorage.getItem('todos')
    if (stored) {
        todos.push(...JSON.parse(stored)) // brittle :)
    }

    function serializeTodos() {
        // performant? no not really. 
        const str = JSON.stringify(todos.map(d => ({ ...d, _comp: undefined })))
        localStorage.setItem('todos', str)
    }
}>
    <div @ root>
        <#run>
            serializeTodos()
        </>
        <input .label-maker autofocus
            placeholder="enter a todo"
            on:keypress(ev) {
                if (ev.key === 'Enter') {
                    const val = this.value.trim()
                    if (!val) return

                    update root {
                        todos.push({
                            label: val,
                        })
                        this.value = ''
                    }
                }
            }
        />
        <#if (todos.length)>
            <main>
                <ul .list>
                    <#run>
                        for (const d of todos) {
                            if (d._comp) update d._comp
                            else d._comp = <Todo todo={d} />
                        }
                    </>
                    {...todos.filter(d => {
                        switch (filterState) {
                            case 'all': return true
                            case 'completed': return d.completed
                            case 'active': return !d.completed
                        }
                    }).map(d => d._comp!.root)}
                </ul>
                <div .filters>
                    <#run>
                        static const m: Record<typeof filterState, string> = {
                            'all': 'ALL',
                            'completed': 'Completed?',
                            'active': 'Active!'
                        }
                        static const buttons = Object.entries(m).map(([k, v]) => (
                            <button .active={k === filterState} on:click() {
                                if (filterState === k) return
                                update root { 
                                    filterState = k as typeof filterState 
                                }
                                for (const b of buttons) update b
                            }>{v}</button>
                        ))
                    </>
                    {...buttons}
                </div>
                <#run>
                    const allCompleted = todos.every(d => d.completed)
                </>
                <button on:click() {
                    update root {
                        for (const d of todos) {
                            d.completed = !allCompleted
                        }
                    }
                }>
                    toggle all {allCompleted ? 'active' : 'completed'}
                </button>
            </main>
            <footer>
                <div .count>
                    {todos.filter(d => !d.completed).length} active TODOs 
                </div>
            </footer>
        </>
        <#if (todos.some(d => d.completed))>
            <button on:click() {
                const active = todos.filter(d => !d.completed)
                update root {
                    todos.splice(0, todos.length, ...active)
                }
            }>
                clear completed todos
            </button>
        </>
    </div>

    <#component Todo(todo: TodoData) {
        let tmpLabel = todo.label
        function save(val: string) {
            if (editingTodo !== todo) return
            const trimmed = val.trim()
            if (!trimmed) return deleteTodo(todo)

            update root {
                editingTodo = undefined
                todo.label = val
                tmpLabel = val
            }
        }
    }>
        <li (.completed={!!todo.completed}, .editing={editingTodo === todo})>
            <label>
                completed
                <input
                    checked={todo.completed}
                    type="checkbox"
                    on:change() {
                        update root {
                            todo.completed = this.checked
                        }
                    }
                />
            </label>
            <#if (editingTodo !== todo)>
                <label on:dblclick() {
                    if (editingTodo === todo) return
                    const p = this.parentElement
                    update root {
                        editingTodo = todo
                    }
                    p?.querySelector('input[type="text"]')?.focus()
                }>{todo.label}</label>
            </>
            <#else>
                <input 
                    type="text"
                    value={tmpLabel}
                    on:input() {
                        tmpLabel = this.value
                    } 
                    on:blur() { save(tmpLabel) }
                    on:keydown(ev) {
                        if (editingTodo !== todo) return
                        if (ev.key === 'Enter') {
                            save(tmpLabel)
                        } else if (ev.key === 'Escape') { 
                            update root {
                                editingTodo = undefined
                                tmpLabel = todo.label
                            }
                        }
                    }
                />
            </>

            <label>
                delete
                <button type="button" on:click() {
                    deleteTodo(todo)
                }>X</button>
            </label>
        </li>
    </>
    <#style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        input.label-maker {
            width: 100%;
            padding: 12px 16px;
            font-size: 16px;
            background: var(--color-background-primary);
            border: 0.5px solid var(--color-border-secondary);
            border-radius: 8px;
            color: var(--color-text-primary);
            outline: none;
        }

        input.label-maker:focus {
            border-color: var(--color-border-primary);
            box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.06);
        }

        input.label-maker::placeholder {
            color: var(--color-text-tertiary);
        }

        main {
            margin-top: 1rem;
            background: var(--color-background-primary);
            border: 0.5px solid var(--color-border-tertiary);
            border-radius: 12px;
            overflow: hidden;
        }

        ul.list {
            list-style: none;
        }

        li {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-bottom: 0.5px solid var(--color-border-tertiary);
        }

        li:last-child {
            border-bottom: none;
        }

        li.completed label:nth-child(2) {
            text-decoration: line-through;
            opacity: 0.45;
        }

        li label, li input[type="text"] {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: var(--color-text-secondary);
            cursor: pointer;
            user-select: none;
        }

        li label:nth-child(2), li input[type="text"] {
            flex: 1;
        }

        li input[type="text"] {
            border: none;
            background: transparent;
            font-size: 15px;
            color: var(--color-text-primary);
            outline: none;
            padding: 0;
            pointer-events: none;
        }

        li.editing input[type="text"] {
            pointer-events: auto;
            border-bottom: 1.5px solid var(--color-border-primary);
            padding-bottom: 2px;
        }

        li input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: #534ab7;
            cursor: pointer;
        }

        li label:nth-child(3) button {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--color-text-tertiary);
            padding: 4px 6px;
            border-radius: 4px;
            opacity: 0;
            transition: opacity 0.1s, color 0.1s;
        }

        li:hover label:nth-child(3) button {
            opacity: 1;
        }

        li label:nth-child(3) button:hover {
            color: #e24b4a;
        }

        div.filters {
            display: flex;
            gap: 6px;
            padding: 10px 16px;
            border-top: 0.5px solid var(--color-border-tertiary);
        }

        div.filters button {
            background: none;
            border: 0.5px solid transparent;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 13px;
            cursor: pointer;
            color: var(--color-text-secondary);
        }

        div.filters button:hover {
            background: var(--color-background-secondary);
        }

        div.filters button.active {
            border-color: var(--color-border-secondary);
            color: var(--color-text-primary);
            font-weight: 500;
        }

        main > button {
            display: block;
            width: 100%;
            padding: 10px 16px;
            background: none;
            border: none;
            border-top: 0.5px solid var(--color-border-tertiary);
            cursor: pointer;
            font-size: 13px;
            color: var(--color-text-secondary);
            text-align: left;
        }

        main > button:hover {
            background: var(--color-background-secondary);
            color: var(--color-text-primary);
        }

        footer {
            margin-top: 12px;
            padding: 0 4px;
        }

        div.count {
            font-size: 13px;
            color: var(--color-text-tertiary);
        }
    </>
</>

document.body.append(<div>
    <div>
        <App/>
    </div>
    <#style>
        div {
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
            margin-top: 100px;
        }

        @unscoped {
            @media (prefers-color-scheme: dark) {
                :root { color-scheme: dark; }
            }
        }

        /* theme vars */
        div {
            --color-background-primary: light-dark(rgba(255, 255, 255, 1), rgba(48, 48, 46, 1));
            --color-background-secondary: light-dark(rgba(245, 244, 237, 1), rgba(38, 38, 36, 1));
            --color-background-tertiary: light-dark(rgba(250, 249, 245, 1), rgba(20, 20, 19, 1));
            --color-text-primary: light-dark(rgba(20, 20, 19, 1), rgba(250, 249, 245, 1));
            --color-text-secondary: light-dark(rgba(61, 61, 58, 1), rgba(194, 192, 182, 1));
            --color-text-tertiary: light-dark(rgba(115, 114, 108, 1), rgba(156, 154, 146, 1));
            --color-border-primary: light-dark(rgba(31, 30, 29, 0.4), rgba(222, 220, 209, 0.4));
            --color-border-secondary: light-dark(rgba(31, 30, 29, 0.3), rgba(222, 220, 209, 0.3));
            --color-border-tertiary: light-dark(rgba(31, 30, 29, 0.15), rgba(222, 220, 209, 0.15));
        }
    </>
</div>)

// Note: should we auto wrap parens after typing `,` in an obvious class list?
// Note: should parens be required for the class list if not using spread? comma is likely enough!
//       or we can do tokens:classList={names} which is ugly but explicit


// 1. Add todos

// * Single text input at the top.
// * Press Enter to create a todo.
// * Empty todos are not allowed.
// * Input clears after creation.

// 2. Display todos

// * Show all todos in a list.
// * Each todo has:

//   * checkbox (complete/incomplete)
//   * label text
//   * delete button

// * Footer and main section are hidden when there are no todos.

// 3. Complete todos

// * Clicking the checkbox toggles completion.
// * Completed items get a visual completed style.

// 4. Edit todos

// * Double-click a todo label to edit.
// * Enter saves changes.
// * Escape cancels editing.
// * Empty edited text deletes the todo.

// 5. Counter

// * Footer shows count of active (incomplete) todos.
// * Example: "3 items left".

// 6. Filters

// * All
// * Active
// * Completed
// * Selecting a filter updates the visible list.
// * Filter state is usually reflected in the URL/hash.

// 7. Toggle all

// * A "Mark all as complete" control.
// * If all are complete, toggling it marks all incomplete.
// * Otherwise it marks all complete. 

// 8. Clear completed

// * Button appears when completed todos exist.
// * Removes all completed todos.

// 9. Persistence

// * Todos survive page refreshes.

