/// <reference lib="jsx" />
/// <reference lib="es2015" />

function static0() {
    return <div>
        <#run>
            static const d = <div />
        </>
        {d}
    </div>
}

function static1() {
    return <div>
        <#run>
            static let c = 0
        </>
        {c++}
    </div>
}


function staticNoInit() {
    return <div>
        <#run>
            static let c
            c = 0
        </>
        {c++}
    </div>
}


function staticCoalesce() {
    return <div>
        <#run>
            let c = 0
            static let c1 = ++c
            static let c2 = ++c
        </>
        {c1++}
        {c2++}
    </div>
}

function staticDependentTreeElement() {
    return <div>
        <#run>
            let c = 0
            // static const d = <div>{c}</div>
            const d2 = <div>{c}</div>
        </>
        {d2}
    </div>
}

function staticClass() {
    return <div @ d>
        <#run>
            static class X {}
            static let last_x: X | undefined
            const needs_update = !!last_x
            // TODO: handle emitting defer inside of <#run>
            // defer if (needs_update) update d 
            const x = new X()
            const is_same_x_ctor = last_x?.constructor === x.constructor
            last_x = x
            if (needs_update) update d 
        </>
        is_same_x_ctor: {String(is_same_x_ctor)}
    </div>
}

function staticFn() {
    return <div @ d>
        <#run>
            static function f() {}
            static let last_f: typeof f | undefined
            const needs_update = !!last_f
            // TODO: handle emitting defer inside of <#run>
            // defer if (needs_update) update d 
            const is_same_fn = f === last_f
            last_f = f
            if (needs_update) update d 
        </>
        is_same_fn: {String(is_same_fn)}
    </div>
}

function staticLazyInit() {
    let q = 0
    return <div @ d>
        <div>
            <#run>
                const y = Math.floor(Math.random()*0.5)
                static let c = ++q + y
            </>
            c: {c++}
            <#run>
                if (c === 2) update d { q += 1 }
            </>
        </div>
        q: {q}
    </div>
}

function staticFnHoist1() {
    return <div>
        <#run>            
            static function f1(a: number, b: number) {
                return a + b
            }
            // this should be a checker error:
            //
            // let c = 0
            // static function f2(a: number, b: number) {
            //     return a + b + c
            // }
            static function transitive1() {
                return f1(1, 2)
            }
            // static function transitive2() {
            //     return f2(1, 2)
            // }
        </>
    </div>
}

function attrHoist() {
    return <div>
        <#run>
            const derived = Math.floor(Math.random()*0.5)
        </>
        <div on:click={() => console.log(derived)}>click</div>
    </div>
}


function attrHoist2() {
    return <div>
        <#run>
            let c = 0
            const derived = Math.floor(Math.random()*0.5)
        </>
        <div on:click={() => console.log(derived, c)}>click</div>
    </div>
}

{
    let c2 = 0
    document.body.append(<div>
        <div @ root>
            <#run>
                let c = 0
            </>
            <div @ view>c: {c} ; c2: {c2}</div>
            <button on:click={() => {
                setTimeout(() => { 
                    update view { 
                        c += 1
                        c2 += 1 
                    } 
                }, 1000)
            }}>+1, delayed</button>
            </div>
        <button on:click={() => {
            update root
        }}>reset</button>
    </div>)
}