/// <reference lib="jsx" />
/// <reference lib="es2015" />

function static0() {
    return <div>
        <#run>
            static const d = <div />
        </>
        {d}
    </div>
}

function static1() {
    return <div>
        <#run>
            static let c = 0
        </>
        {c++}
    </div>
}


function staticNoInit() {
    return <div>
        <#run>
            static let c
            c = 0
        </>
        {c++}
    </div>
}


function staticCoalesce() {
    return <div>
        <#run>
            let c = 0
            static let c1 = ++c
            static let c2 = ++c
        </>
        {c1++}
        {c2++}
    </div>
}

function staticClass() {
    return <div @ d>
        <#run>
            static class X {}
            static let last_x: X | undefined
            const needs_update = !last_x
            // TODO: handle emitting defer inside of <#run>
            // defer if (needs_update) update d 
            const x = new X()
            const is_same_x_ctor = last_x?.constructor === x.constructor
            last_x = x
            if (needs_update) update d //THIS IS WRONG
        </>
        is_same_x_ctor: {String(is_same_x_ctor)}
    </div>
}

function staticFn() {
    return <div @ d>
        <#run>
            static function f() {}
            static let last_f: typeof f | undefined
            const needs_update = !last_f
            // TODO: handle emitting defer inside of <#run>
            // defer if (needs_update) update d 
            const is_same_fn = f === last_f
            last_f = f
            if (needs_update) update d 
        </>
        is_same_fn: {String(is_same_fn)}
    </div>
}

function staticLazyInit() {
    let q = 0
    return <div @ d>
        <div>
            <#run>
                const y = Math.floor(Math.random()*0.5)
                static let c = ++q + y
            </>
            c: {c++}
            <#run>
                if (c === 2) update d { q += 1 }
            </>
        </div>
        q: {q}
    </div>
}

function staticFnHoist1() {
    return <div>
        <#run>            
            static function f1(a: number, b: number) {
                return a + b
            }
            static function transitive1() {
                return f1(1, 2)
            }
        </>
        {f1(1,2)+transitive1()}
    </div>
}

function attrHoist() {
    return <div>
        <#run>
            const derived = Math.floor(Math.random()*0.5)
        </>
        <div on:click={() => console.log(derived)}>click</div>
    </div>
}


function attrHoist2() {
    return <div>
        <#run>
            let c = 0
            const derived = Math.floor(Math.random()*0.5)
        </>
        <div on:click={() => console.log(derived, c)}>click</div>
    </div>
}

{
    let c2 = 0
    document.body.append(<div>
        <div @ root>
            <#run>
                let c = 0
            </>
            <div @ view>c: {c} ; c2: {c2}</div>
            <button on:click={() => {
                setTimeout(() => { 
                    update view { 
                        c += 1
                        c2 += 1 
                    } 
                }, 1000)
            }}>+1, delayed</button>
            </div>
        <button on:click={() => {
            update root
        }}>reset</button>
    </div>)
}

function manyStatic() {
    return <div>
        <#run>
            const m = Math.random()
            static const m2 = m+Math.random()
            const m3 = Math.random()
            static const m4 = m3+Math.random()
            const m5 = Math.random()
            static const m6 = m5+Math.random()
            const m7 = m6+Math.random()
        </>
        {m7}
    </div>
}


{
    <#component Foo(children)>
        <div>{...children}</div>
    </>

    <#component Bar(children)>
        <Foo>
            {children[0]}
            <div>
                <#run>
                    static let c
                    c = 0
                </>
                {c++}
            </div>
        </Foo>
    </>
}

{
  <#component Foo(children) { let c = 0; public { Bar } }> 
    <div> 
      <div @ d>c is: {c}</div> 
      <Bar inc=2 /> 
      <div>{...children}</div>
    </div> 
    <#component Bar(inc = 1)> 
      <div on:click() { update d { c += inc } }>click! {inc}</div> 
    </>
  </>
  document.body.append(<Foo @ f> <f.Bar inc=3 /> </Foo>.root)
}


{
  <#component Foo(children) {
    let seconds = 0
  }>
    <div @ v>
        <#run>
            static let t
            if (!v.isConnected) {
                clearInterval(t)
                t = undefined
            } else {
                t ??= setInterval(() => {
                    update v { seconds += 1 }
                }, 1_000)
            }
        </>
        <div>seconds: {seconds}</div>
        <div>{...children}</div>
    </div>
  </>
  document.body.append(<div @ d>
    <#run>
      static let cond = false
      static let count = 0
    </>
    <button on:click() {
      update d {
        cond = !cond
      }
    }>
        toggle: {String(cond)}
    </button>
    <Foo>
      <#if (cond)>
        <#run>
          count += 1
          let cond2 = false
          static let timerFiredCount = 0
        </>
        <div>test!</div>
        <#if (count % 2 === 0)>
            <div @ d2>
                <div>even</div>
                <button on:click() {
                    update d2 { cond2 = !cond2 }
                    setTimeout(() => { 
                        update d2 { 
                            cond2 = false
                            timerFiredCount += 1
                        } 
                    }, 10_000)
                }>toggle "hello"</button>
                <#if (cond2)>
                    <div>hello! {timerFiredCount}</div>
                </>
            </div>
        </>
        <#else>
          <div>odd</div>
        </>
      </>
    </Foo>
  </div>)
}
