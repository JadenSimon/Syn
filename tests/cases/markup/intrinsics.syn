/// <reference lib="jsx" />
/// <reference lib="es2015" />

function staticAttrs() {
    return <input type="text" placeholder="enter value" />
}

function staticBoolAttrs() {
    return <input checked />
}

function dynamicProp(checked: boolean) {
    return <input type="checkbox" checked={checked} />
}

function camelCaseProp() {
    return <iframe marginWidth=100></iframe>
}

function attrAlias(readOnly: boolean) {
    return <input readonly={readOnly} />
}

function shorthandAttr(readonly: boolean) {
    return <input {readonly} />
}

function attrSetAttributeFallback(itemid: string) {
    return <div itemid={itemid}></div>
}

function dataAttr(val: string) {
    return <div data-value={val}></div>
}

function ariaAttr(label: string) {
    return <button aria-label={label}>x</button>
}

function classAlias(cls: string) {
    return <div class={cls}></div>
}

function spreadAttrs(o: {}) {
    return <div {...o}></div>
}

function spreadAttrs2(o: {}, o2: {}) {
    return <div {...o} {...o2} />
}

function spreadAttrs3(o: {}) {
    return <div class="a" {...o} />
}

function spreadAttrs4(o: {}) {
    return <div {...o} class="a" />
}

function spreadAttrs5(o: {}, value: string) {
    return <input {...o} {value} /> // TODO: this emit could use shorthand prop directly, parser needs to mark shorthands
}
