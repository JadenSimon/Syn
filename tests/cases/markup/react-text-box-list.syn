/// <reference lib="jsx" />
/// <reference lib="es2015" />

<#component TextBoxList() {
  const items: Element[] = []
}>
  <ul @ list>
    {...items}
    <input
      type="button"
      value="Add an item"
      on:click={() => {        
        const item = <li>
          <input
            type="text"
            placeholder="change me!"
          />
        </li>

        update list {
          items.push(item)
        }
      }}
    />
  </ul>
</>

document.body.append(
  <div>
    <p>
      Existing inputs are never recreated because the code doesn't say to do that
    </p>
    <TextBoxList />
  </div>
)

//     <p>Every time you add a new text box to the list, we "re-render" the whole list, but any text entered in the text boxes is left untouched because React is smart enough to just append the new text box instead of blowing away the old DOM nodes.</p>
