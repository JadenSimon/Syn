/// <reference lib="jsx" />
/// <reference lib="es2015" />

{
    <#component Foo(children) {
        public { Bar }
        let c = 0
        public function inc() { c += 1 }
        let dashes = 0
        public function incDash() { dashes += 1 }
        public function decDash() { dashes -= 1 }
    }>
    <div>
        <div>c: {c}</div>
        ----
        {...children}
    </div>
    <#component Bar(children)>
        <div>
            Bar: {c}
            -----{'-'.repeat(dashes)}
            {...children}
        </div>
    </>
    </>

    const f = <Foo>
        <f.Bar>
            <f.Bar></f.Bar>
        </f.Bar>
        <f.Bar>
            <f.Bar></f.Bar>
        </f.Bar>
    </Foo>
    document.body.append(f.root)
    setTimeout(() => { update f { f.inc() } } , 1000)
}

function createMountHook(el: Element) {
    let connected = false
    let dispose: (() => void) | void

    return (cb: () => typeof dispose) => {
        const next = el.isConnected
        if (next && !connected) {
            dispose?.()
            dispose = cb()
            connected = true
        } else if (!next && connected) {
            dispose?.()
            dispose = undefined
            connected = false
        }
    }
}

<#component Timer(start = 0) {
    let seconds = start
    public function reset() {
        update d { seconds = 0 }
    }
}>
    <div @ d>
        Seconds: {seconds}
    </div>

    <#run>
        static const onMount = createMountHook(d)
        onMount(() => {
            const t = setInterval(() => {
                update d { seconds += 1 }
            }, 1000)
            return () => clearInterval(t)
        })
    </>
</>

{

    const qq = <div>
        <#run>
            static let visible = true
            static let _t
        </>
        <#if (visible)>
            <Timer @ t />
            <button on:click={() => t.reset()}>reset</button>
            <#run>
                _t = t
            </>
        </><#else>
            <#run>
                if (_t) _t = void (update _t)
            </>
        </>
        <button on:click={() => { 
            update qq { visible = !visible } 
        }}>toggle</button> 
    </div>
    document.body.append(qq)
    update qq
}


const timer = <Timer />
document.body.append(timer.root)
update timer

