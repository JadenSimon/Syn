/// <reference lib="jsx" />
/// <reference lib="es2015" />

<#component List<T>(items: T[], children: [(x: T) => Node], key?: (x: T) => string | number) {
  const m = new Map<string | number | T, Node>()
  // if you want, add some state to track key/children 
  // to know if they changed and clear `m`
}>
  <#run>
    const elements = new Set<Node>()
    for (let i = 0; i < items.length; i++) {
      const x = items[i]
      const k = key?.(x) ?? (x && typeof x === 'object' ? x : i)
      let n = m.get(k)
      // BUG: we get an infinite loop when getting the type for `children[0](x)`
      // BUG: we do not seem to detect assignments inside args of call expressions
      // if (!n) m.set(k, n = children[0](x))
      elements.add(n)
    }
    // clean up!
    for (const [k, v] of m) {
      if (!elements.has(v)) m.delete(k)
    }
  </>
  {...Array.from(elements)}
</> 


const items = [
  { id: 1, first: '1', last: '2' },
  { id: 2, first: '3', last: '4' }
]

let nextId = 3

document.body.append(<div @ root>
  <div style="margin-bottom: 8px;">
    <button on:click={() => {
      update root {
        items.push({ id: nextId++, first: String(nextId), last: String(nextId + 1) })
      }
    }}>
      add
    </button>

    <button on:click={() => {
      update root {
        items.reverse()
      }
    }}>
      reverse
    </button>

    <button on:click={() => {
      update root {
        items.sort((a, b) => a.first.localeCompare(b.first))
      }
    }}>
      sort
    </button>

    <button on:click={() => {
      update root {
        items.pop()
      }
    }}>
      remove last
    </button>
  </div>

  <...List {items} key={x => x.id}>
    {x => <div>{x.first} {x.last}</div>}
  </List>
</div>)
