// sibling ifs
function siblingIfs(a: boolean, b: boolean) {
    return <div>
        <#if (a)>
            <span>a</span>
        </>
        <#if (b)>
            <span>b</span>
        </>
    </div>
}

// if with binding
function ifWithBinding(show: boolean) {
    return <div>
        <#if (show)>
            <span @ el>hello</span>
        </>
    </div>
}
