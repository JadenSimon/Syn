/// <reference lib="jsx" />
/// <reference lib="es2015" />

function basicIf(show: boolean) {
    return <div>
        <#if (show)>
            <span>hello</span>
        </>
    </div>
}

function ifElse(show: boolean) {
    return <div>
        <#if (show)>
            <span>yes</span>
        </><#else>
            <span>no</span>
        </>
    </div>
}

function ifExpr(count: number, show: boolean) {
    return <div>
        <#if (show)>
            {count}
        </>
    </div>
}

function ifElseExpr(val: string, show: boolean) {
    return <div>
        <#if (show)>
            {val}
        </><#else>
            {"hidden"}
        </>
    </div>
}

function siblingIfs(a: boolean, b: boolean) {
    return <div>
        <#if (a)>
            <span>a</span>
        </>
        <#if (b)>
            <span>b</span>
        </>
    </div>
}

function ifWithBinding(show: boolean) {
    return <div>
        <#if (show)>
            <span @ el>hello</span>
        </>
    </div>
}

function singleSlotNoEffects(show: boolean) {
    return <div>
        <#if (show)>
            1
        </><#else>
            2
        </>
    </div>
}

function branchWithBinding(show: boolean) {
    return <div>
        <#if (show)>
            <div @ d>
                <#run>
                    console.log(d)
                </>
            </div>
        </><#else>
            0
        </>
    </div>
}

function conditionalComponentInstanceChildren(cond: boolean) {
    <#component Inner(children: (Text | string)[])>
        <div>{...children}</div>
    </>
    return <div>
        <Inner>
            <#if (cond)>
                test
            </>
        </Inner>
    </div>
}

function conditionalComponentInstanceChildren2(cond: boolean) {
    <#component Inner(children: (Text | string)[])>
        <div>{...children}</div>
    </>
    return <div>
        <Inner>
            <#if (cond)>
                test
            </>
            <#else>
                test2
            </>
        </Inner>
    </div>
}

function conditionalComponentInstanceChildren3(cond: boolean) {
    <#component Inner(children: (Text | string)[])>
        <div>{...children}</div>
    </>
    let x = 'aaa'
    return <div>
        <Inner>
            <#if (cond)>
                test
                {x} {x}
            </>
            <#else>
                test2
                {x.repeat(2)} {x.repeat(3)}
            </>
        </Inner>
    </div>
}

function conditionalComponentInstanceChildren4(cond: boolean) {
    <#component Inner(children: (Text | string)[])>
        <div>{...children}</div>
    </>
    let x = 'aaa'
    return <div>
        <Inner>
            <#if (cond)>
                test
            </>
            <#else>
                test2
                {x.repeat(2)} {x.repeat(3)}
            </>
        </Inner>
    </div>
}

function branchRetention() {
    let cond = true
    return <div @ o>
        <#if (cond)>
            <div @ d>d</div>
            <#run>
                static {
                    d.after('test!')
                    update o { cond = !cond }
                    setTimeout(() => {
                        update o { cond = !cond }
                    }, 2000)
                }
            </>
        </>
    </div>
}

function branchRetention2() {
    <#component Foo(children)>
        <div>{...children}</div>
    </>
   let cond = true
    document.body.append(<Foo @ o>
        <#if (cond)>
            <div @ d>d</div>
            <#run>
                static {
                    d.after('test!')
                    update o { cond = !cond }
                    setTimeout(() => {
                        update o { cond = !cond }
                    }, 2000)
                }
            </>
        </>
    </Foo>.root)
}