/// <reference lib="jsx" />
/// <reference lib="es2015" />

// basic if: render element conditionally
function basicIf(show: boolean) {
    return <div>
        <#if (show)>
            <span>hello</span>
        </>
    </div>
}

// if/else: two branches
function ifElse(show: boolean) {
    return <div>
        <#if (show)>
            <span>yes</span>
        </><#else>
            <span>no</span>
        </>
    </div>
}

