/// <reference lib="jsx" />
/// <reference lib="es2015" />

function basicIf(show: boolean) {
    return <div>
        <#if (show)>
            <span>hello</span>
        </>
    </div>
}

function ifElse(show: boolean) {
    return <div>
        <#if (show)>
            <span>yes</span>
        </><#else>
            <span>no</span>
        </>
    </div>
}

