function siblingIfs(a: boolean, b: boolean) {
    return <div>
        <#if (a)>
            <span>a</span>
        </>
        <#if (b)>
            <span>b</span>
        </>
    </div>
}

function ifWithBinding(show: boolean) {
    return <div>
        <#if (show)>
            <span @ el>hello</span>
        </>
    </div>
}

function ifWithUnwind(show: boolean) {
    return <div>
        <#run>
            unwind { console.log('2') }
        </>
        <#if (show)>
            test
            <#run>
                unwind { console.log('1') }
            </>
        </><#else>
            t
        </>
    </div>
}

function singleSlotNoEffects(show: boolean) {
    return <div>
        <#if (show)>
            1
        </><#else>
            2
        </>
    </div>
}

function branchWithBinding(show: boolean) {
    return <div>
        <#if (show)>
            <div @ d>
                <#run>
                    console.log(d)
                </>
            </div>
        </><#else>
            0
        </>
    </div>
}

function conditionalComponentInstanceChildren(cond: boolean) {
    <#component Inner(children: NodeLike[])>
        <div>
            {...children}
        </div>
    </>
    return <div>
        <Inner>
            <#if (cond)>
                test
            </>
        </Inner>
    </div>
}

