/// <reference lib="jsx" />
/// <reference lib="es2015" />

<#component Inner(children: (ChildNode | string)[]) {
  const a = document.createComment('')
  const b = document.createComment('')
  let len = 0
}>
  {a}
  {b}
  <#run>
    let cur = a.nextSibling
    let i = 0
    while (cur && cur !== b) {
      const n = cur
      cur = cur.nextSibling
      if (i >= children.length) {
        n.remove()
        continue
      }
      const c = children[i++]
      if (n === c || (n.nodeType === 3 && typeof c !== 'object' && n.nodeValue === String(c))) continue
      // if (n === c) continue
      // if (n.nodeType === 3 && typeof c !== 'object') {
      //   n.nodeValue = c
      //   continue
      // }
      if (len > children.length) {
        i--
        n.remove()
        len -= 1
      } else if (len < children.length) {
        cur = n
        cur.before(c)
        len += 1
      } else n.replaceWith(c)
    }
    while (i < children.length) b.before(children[i++])
    len = i
  </>
</>


<#component WithSpread(items: string[])>
  <div>
    <...Inner>
      {...items}
    </Inner>
  </div>
</>

const items: string[] = []
const c = <WithSpread {items} />
let flipped = false

document.body.append(
  <div on:click={() => {
    const t = setInterval(() => {
      if (items.length === 500) {
        clearInterval(t)
        items.length = 250
        flipped = !flipped
      } else {
        const s = `item-${items.length}`
        update c {
          if (flipped) {
            items.unshift(s)
          } else {
            items.push(s)
          }
        }
      }
    }, 5)
  }}>
    update items
  </div>,
  c.root
)
