/// <reference lib="jsx" />
/// <reference lib="es2015" />

function staticText() {
    return <div>hello world</div>
}

function singleExpr(v: string) {
    return <div>{v}</div>
}

function multiExpr(a: string, b: string) {
    return <div>{a} and {b}</div>
}

function multiExprSpaced(a: string, b: string) {
    return <div>{a} {b}</div>
}

function multiExprSpaced2(a: string, b: string) {
    return <div>{a}   {b}</div>
}

function multiExprMultiline(a: string, b: string) {
    return <div>
        {a}
        {b}
    </div>
}

function mixedStaticDynamic(name: string) {
    return <div>hello {name}!</div>
}

function pureExpr() {
    const x = 'hello'
    return <div>{x}</div>
}

function singularSpread(items: (string | number | ChildNode)[]) {
    return <div>{...items}</div>
}

function mixedSpread(items: (string | number | ChildNode)[]) {
    return <div>before: {...items} :after</div>
}

function mutations() {
    let x = <span id ="a" />
    const d = <div>
        <span />
        {x}
    </div>

    // TODO: types should start narrowed for known JSX syntax trees ?
    const s = d.firstElementChild!
    s.after(<span id="b" />)
    x.before(<span id="c" />)
    x.after(<span id="d" />) // this orphans `x` under the current impl
    update d { x = <span id="e" /> }
    x.remove()
    update d { x = x }
}

function multilineElements(a: string) {
    return <div>
        <span>1</span>
        <span>{a}</span>
    </div>
}

function multilineElements2() {
    return <div>
        <span>1</span>
           <span>2</span>
    </div>
}

function spacedElements() {
    return <div>
        <span>1</span>   <span>2</span>
    </div>
}

function multilineText() {
    return <div>
        hello
        world
    </div>
}

function multilineText2() {
    return <div>   a
    
                b   </div>
}

function multilineText3() {
    return <div>   a
                {'c'}
                b   </div>
}

function multilineTextFragment() {
    return <div>
        <>This is text</>
        <> across multiple lines</>
    </div>
}

function samelineText() {
    return <div>   a   b   </div>
}

function samelineTextEmpty() {
    return <div>   </div>
}
