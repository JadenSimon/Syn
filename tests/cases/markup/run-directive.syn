/// <reference lib="jsx" />
/// <reference lib="es2015" />

function basicRun(x: number) {
    return <div>
        <#run>
            console.log(x)
        </>
        {x}
    </div>
}

function runDeclaredVar(items: string[]) {
    return <div>
        <#run>
            const count = items.length
        </>
        {count}
    </div>
}

// TODO: shadowing inside of #run (probably) breaks, we might need blocks inside the update fn in some cases

function runWithUnwind() {
    return <div>
        <#run>
            const id = setInterval(() => {}, 500)
            unwind { clearInterval(id) }
        </>
    </div>
}

function runWithBinding(active: boolean) {
    return <div>
        <span @ el></span>
        <#run>
           el.hidden = !active
        </>
    </div>
}

function runOnComponent(rate: number) {
    return <div @ root>
        <#run>
            if (rate) {
                const id = setInterval(() => {}, rate)
                unwind { clearInterval(id) }
            }
        </>
    </div>
}
