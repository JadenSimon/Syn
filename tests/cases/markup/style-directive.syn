/// <reference lib="jsx" />
/// <reference lib="es2015" />

function compiledClass() {
    <#style>
        .a { color: red; }
    </>
    return <div .a>red!</div>
}


function sharedScope() {
    // these should be merged to use one scoped attr
    // the __style call should be be inserted at the 1st <#style> directive
    // and subsequent directives _in the same scope_ don't emit any code
    <#style>
        div { color: red; }
    </>
    <#style>
        div { background: blue; }
    </>
    return <div />
}

function nestedScopes(cond: boolean, cond2: boolean) {
    // the 1st <#style> directive in a lexical scope chain defines where the scoped
    // attr starts. We visit all children from this point to create hash which all
    // subscoped styles share. Subscoped styles emit their own `__style` call and 
    // allocate a number to refine their scope. These are added as extra attributes.
    //
    // these subscoped selectors are about 1.2x slower than the root selector
    // (Chrome Version 146.0.7680.75 arm64)

    // div[_abcd1234]
    <#style>
        div { color: red; background: black; }
    </>
    if (cond) {
        // div[_abcd1234]:where([_s-1])
        <#style>
            div { color: blue; }
        </>
        if (cond2) {
            // div:hover[_abcd1234]:where([_s-1][_s-2])
            <#style>
                div:hover { color: purple; }
            </>
            // <div _abcd1234 _s-1 _s-2></div>
            return <div />
        }
        // <div _abcd1234 _s-1></div>
        return <div />
    }
    // <div _abcd1234></div>
    return <div />
}

function nestedFnScopes() {
    <#style>
        div { color: red; }
    </>
    function f() {
        <#style>
            div { background: black; }
        </>
        return <div />
    }
    return f
}

function unscoped() {
    <#style>
        div.foo { color: red; }
        :unscoped(.foo) { color: blue; }
        div:unscoped(.foo) span { color: green; } /* TODO: reconsider this case, it's functionally useless */
        :unscoped(div.foo) span { color: green; }
    </>
    return <div .foo></div>
}

function unscopedAtRule() {
    <#style>
        @unscoped {
            div.foo { color: red; animation: bar; }
            @keyframes bar {}
            .bar { animation-name: bar; }
        }
    </>
    return <div .foo></div>
}

function scopeAtRule() {
    <#style>
        .x {}
        @scope (.x) {
            .y {}
            @keyframes k {} /* still scoped */
        }
    </>
    return <div .x>
        <div .y></div>
    </div>
}

function layerAtRule() {
    <#style>
        @layer t { .btn {} }
    </>
    return <button .btn></button>
}

function fontFaceAtRule() {
    <#style>
        @font-face { font-family: 'test' }
    </>
}

