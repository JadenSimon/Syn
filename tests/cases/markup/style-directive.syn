// FIXME (vsc extension): selecting the closing tag + LT token and typing slash should auto-close tag as self-closing: `<div></div>`

function mediaAtRule() {
    <#style>
        @media screen and (width = 900px) {
            @keyframes k {}
            div { color: red; }
        }
    </>
    return <div></div>
}

function pseudoAttr() {
    <#style>
        div::before {
            content: "before";
            color: blue;
        }
    </>
    return <div></div>
}

function nestedCss() {
    <#style>
        .a {
            color: blue;
            & { background: black; }
            &,.b2 { background: black; }
            & .b2 { background: black; }
            .b2[data-x="&"] { background: black; }
            .b {
                color: red;
                .c { border: green; }
            }
        }
    </>
    return <div .a>a
        <div .b>b
            <div .c>c</div>
        </div>
    </div>
}

function keyframes() {
    <#style>
        .test {
            color: blue;
            animation: test 1s infinite;
        }
        @keyframes test {
            to {
                color: red;
            }
        }
    </>
    return <div .test></div>
}

function keyframesDifferentName() {
    <#style>
        .test {
            color: blue;
            animation: test2 1s infinite;
        }
        @keyframes test {
            to { color: red; }
        }
    </>
    return <div .test></div>
}

function keyframesAnimationName() {
    <#style>
        .test {
            animation: 1s infinite;
            animation-name: test;
        }
        @keyframes test {
            to { color: red; }
        }
    </>
    return <div .test></div>
}

function keyframesMultiAnimation() {
    <#style>
        .test {
            color: blue;
            background: red;
            animation: t1 1s, t2 1s;
            animation-name: t1, t2;
        }
        @keyframes t1 {
            to { color: red; }
        }
        @keyframes t2 {
            to { background: blue; }
        }
    </>
    return <div .test></div>
}

// FIXME: `not` and `has` need to be handled specially
// also, we can skip transforming every selector in `is`/`where` if we augment the base
function pseudoClasses() {
    <#style>
        :is(div) {}
        :where(div) {}
        :has(div) {}
        :not(div) {}
    </>
}

function unknownAtRule() {
    <#style>
        @unknown-rule {}
        @unknown-rule;
        div {
            @unknown-rule {}
            @unknown-rule;
            color: red;
            div { div { color: red } }
        }
    </>
}

// FIXME: this breaks the TM grammar?
function ambiguousNestedCss() {
    <#style>
        background:color {
            div { color: red }
            background: black
        }
    </>
}

// FIXME: the emitter needs to escape ``` and `\` for synthetic template literals
function escapes() {
    <#style>
        [data-x=\{] {
            color: red;
            &::before {
                content: "\"";
            }
            div { & { color: blue } [attr=\&] { color: red } }
        }
        .\A9 0 {}
        .\0000A90 {}
        div {
            --\@: red;
            color: var(--\@);
        }
        /* TODO: we need to normalize property names when parsing to handle this case
        /* div {
            \-\-x:div{color:red;};
            color:green;
        } */
    </>
}

function comments() {
    <#style>
        div /*.a*/ {
            color: green;
            div/*:red;*/{}
            /*}*/
            background: /* ; */ black;
        }
        /* div {} */
        @keyframes a {}
        div {
            animation-name: /* a */ b;
            animation-name: a;
        }
    </>
}

function customPropAtRule() {
    <#style>
        div {
            --foo: @keyframes a {};
            --foo: @keyframes a {}
        }
    </>
}

function customPropNestedRule() {
    <#style>
        div {
            --foo: div{color:blue};
            --foo: div{color:blue}
        }
    </>
}

function customPropMixedBlocks() {
    <#style>
        div {
            --foo: ([}][(])]);color:red;div{color:blue}
        }
    </>
}
