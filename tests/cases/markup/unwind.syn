/// <reference lib="jsx" />
/// <reference lib="es2015" />

function partial() {
    let t = 0
    let c1 = 0
    let c2 = 0
    return <div @ d1>
        <#run>
            c1 += 1
            unwind {
                t += 1
                c1 -= 1
            }
        </>
        <div>t: {t}</div>
        <div>c1: {c1}</div>
        <div @ d2>
            <#run>
                unwind { c2 += 1 }
            </>
            c2: {c2}
        </div>
        <button on:click={() => {
            update d1
        }}>
            update d1
        </button>
        <button on:click={() => {
            update d2
        }}>
            update d2
        </button>
    </div>
}

function unmount() {
    <#component Foo() {
        let c = 0
        let t = 0
        let paused = false
        public function resume() {
            paused = false
            t ||= setInterval(() => {
                if (paused) {
                    clearInterval(t)
                    t = 0
                    return
                }
                update s { c += 1 }
            }, 1000)
        }
        public function pause() {
            paused = true
        }
    }>
        <div>
            <span @ s>counter: {c}</span>
        </div>
    </>

    let show = false
    return <div @ d>
        <#if (show)>
            <Foo @ f />
            <#run>
                f.resume()
                unwind { f.pause() }
            </>
        </>
        <button on:click={() => {
            update d { show = !show }
        }}>
            toggle
        </button>
    </div>
}

// <#component Foo() {} satisfies { attributes: {}; unmount(): void }>