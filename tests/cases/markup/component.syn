/// <reference lib="jsx" />
/// <reference lib="es2015" />

<#component Styled() {}>
  <div>hello</div>
  <#style>
    div { color: red }
  </>
</>

<#component Button(label: string) {}>
  <button>{label}</button>
</>

function useButton(label: string) {
    return <Button {label} />
}

<#component Card(title: string) {}>
  <div>{title}</div>
</>

function withCard(title: string) {
    return <div>
        <Card {title} />
    </div>
}

<#component Row(a: string, b: string) {}>
  <span>{a}</span>
  <span>{b}</span>
</>

<#component Inner(children: (ChildNode | string)[]) {}>
  {...children}
</>

function withSpread(items: string[]) {
    return <div>
        <...Row a="1" b="2" />
        <...Inner>
            {...items}
        </Inner>
    </div>
}

<#component Inner2(children: (ChildNode | string)[])>
  <...Inner>
    <...Row a="3" b="4" />
  </Inner>
  {...children}
</>

function withSpread2() {
  return <div>
    <...Inner2>
      <...Inner2>
        <span>5</span>
        <span>6</span>
      </Inner2>
    </Inner2>
  </div>
}

<#component NestedOuter() {
  let c = 0
  let selected: number = -1
}>
  <div @ root>
    <#component NesterInner() {
      const id = c++
      let counter = 0
    }>
      <div 
        .selected={selected === id} 
        style="padding: 16px; width: fit-content;"
      >
        <div>id: {id}</div>
        <div @ view>
          counter: {counter}
        </div>
        <button on:click={() => {
          update view { counter += 1 }
          if (selected !== id) {
            update root {
              selected = id
            }
          }
        }}>
          increment
        </button>
      </div>
      <#style>
        .selected {
          border: 1px solid blue;
          font-weight: bold;
        }
      </>
    </>
    <NesterInner />
    <NesterInner />
  </div>
</>

{
  <#component Squared(x: number) {
    let updateCount = 0
  }>
    <div>
      <div>update count: {++updateCount}</div>
      x * x = {x * x}
    </div>
  </>

  let x = 0
  document.body.append(<div @ d>
    <Squared {x} />
    <button on:click={() => { 
      update d { x += 1 } 
    }}>
      inc x: {x}
    </button>
  </div>)
}

<#component SharedScope() {
  function register(el: Element) {}
  setTimeout(() => register(d))
}>
  <div @ d></div>
</>

{
  let c = 0
  let ids = 0
  <#component Comp(a: number, children: Node[]) {
    const id = ids++
  }>
    <div>
      id: {id}; a: {a}; c: {c++}
      <div>
        {...children}
      </div>
    </div>
  </>
  document.body.append(<div @ d>
    <Comp a={c}>
      <Comp a={c}></Comp>
      <Comp a={c}></Comp>
    </Comp>
    <button on:click={() => { update d }}>update</button>
  </div>)
}

