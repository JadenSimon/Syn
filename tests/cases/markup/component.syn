/// <reference lib="jsx" />
/// <reference lib="es2015" />

<#component Styled() {}>
  <div>hello</div>
  <#style>
    div { color: red }
  </>
</>

<#component Button(label: string) {}>
  <button>{label}</button>
</>

function useButton(label: string) {
    return <Button {label} />
}

<#component Card(title: string) {}>
  <div>{title}</div>
</>

function withCard(title: string) {
    return <div>
        <Card {title} />
    </div>
}

<#component Row(a: string, b: string) {}>
  <span>{a}</span>
  <span>{b}</span>
</>

<#component Inner(children: (ChildNode | string)[]) {}>
  {...children}
</>

function withSpread(items: string[]) {
    return <div>
        <...Row a="1" b="2" />
        <...Inner>
            {...items}
        </Inner>
    </div>
}

<#component Inner2(children: (ChildNode | string)[])>
  <...Inner>
    <...Row a="3" b="4" />
  </Inner>
  {...children}
</>

function withSpread2() {
  return <div>
    <...Inner2>
      <...Inner2>
        <span>5</span>
        <span>6</span>
      </Inner2>
    </Inner2>
  </div>
}

<#component NestedOuter() {
  let c = 0
  let selected: number = -1
}>
  <div @ root>
    <#component NesterInner() {
      const id = c++
      let counter = 0
    }>
      <div 
        .selected={selected === id} 
        style="padding: 16px; width: fit-content;"
      >
        <div>id: {id}</div>
        <div @ view>
          counter: {counter}
        </div>
        <button on:click={() => {
          update view { counter += 1 }
          if (selected !== id) {
            update root {
              selected = id
            }
          }
        }}>
          increment
        </button>
      </div>
      <#style>
        .selected {
          border: 1px solid blue;
          font-weight: bold;
        }
      </>
    </>
    <NesterInner />
    <NesterInner />
  </div>
</>

{
  <#component Squared(x: number) {
    let updateCount = 0
  }>
    <div>
      <div>update count: {++updateCount}</div>
      x * x = {x * x}
    </div>
  </>

  let x = 0
  document.body.append(<div @ d>
    <Squared {x} />
    <button on:click={() => { 
      update d { x += 1 } 
    }}>
      inc x: {x}
    </button>
  </div>)
}

<#component SharedScope() {
  function register(el: Element) {}
  setTimeout(() => register(d))
}>
  <div @ d></div>
</>

{
  let c = 0
  let ids = 0
  <#component Comp(a: number, children: ChildNode[]) {
    const id = ids++
  }>
    <div>
      id: {id}; a: {a}; c: {c++}
      <div>
        {...children}
      </div>
    </div>
  </>
  document.body.append(<div @ d>
    <Comp a={c}>
      <Comp a={c}></Comp>
      <Comp a={c}></Comp>
    </Comp>
    <button on:click={() => { update d }}>update</button>
  </div>)
}

{
  <#component Foo() {
    let c = 0
    public function inc() { update d { c++ } }
  }>
    <div @ d>{c}</div>
  </>

  // usage
  document.body.append(<div>
    <Foo @ f />
    <button on:click={() => f.inc()}>click!</button>
  </div>)
}

{
  <#component NestedSync(x: string) {
    // public { Foo } ???
    public function getFoo() {
      return Foo
    }
  }>
    <#run>
      const d = x.repeat(2)
    </>
    <div>
      d: {d}
    </div>

    <#component Foo(y: string | number)>
      <div>
        d: {d}
        y: {y}
      </div>
    </>
  </>
  document.body.append(<div @ root>
    <#run>
      // TODO: NestedSync.Foo
      static const comps: any[] = []
      function addFoo() {
        const Foo = n.getFoo()
        const id = comps.length
        const inst = <Foo y={id} />
        update list { 
          comps.push(inst) 
        }
      }
      static let val = ''
    </>
    <NestedSync @ n x={val} />
    <label>
      change val:
      <input on:input={ev => {
        update root {
          val = ev.currentTarget.value
        }
      }} />
    </label>
    <div @ list>
      {...comps.map(x => x.root)}
      <#run>
        for (const c of comps) update c
      </>
    </div>
    <button on:click={addFoo}>add Foo</button>
  </div>)
}

