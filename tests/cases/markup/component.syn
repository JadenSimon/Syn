{
  <div>
    <div @ outer> 
      <#run> 
        let c = 0 
      </> 
      <div @ view>c: {c}</div> 
      <#component Foo()> 
        <button on:click={() => { 
          setTimeout(() => { update view { c += 1 } }, 1000) }
        }>delayed inc</button> 
      </>
      <Foo />
    </div> 
    <button on:click={() => { update outer }}>back to zero</button>
  </div>
}

{
  <#component Imm(x: string)>
    <Inner y={x.repeat(2)}/>
    <#component Inner(y: string)>
      <div>{x} : {y}</div>
    </>
  </>

  <#component Run()>
    <#run>
      console.log('1')
    </>
    <div @ d>
      <#run>
        console.log('2')
      </>
    </div>
  </>
}